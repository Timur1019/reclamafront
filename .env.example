# Копируй в .env.production.local или задай в Render (Static Site → Environment)
# URL бэкенда без завершающего слэша. Имя ключа должно быть именно VITE_API_BASE (с префиксом VITE_).
# После добавления переменной: Save → выбери «rebuild» / новый deploy, иначе в бандле останется старый URL.
VITE_API_BASE=https://reclama-5go0.onrender.com

# Необязательно: если пусто, при сборке берётся из VITE_API_BASE (wss/https)
# VITE_WS_URL=wss://reclama-api.onrender.com/ws

# --- Docker / Render (Web Service + Dockerfile) ---
# При сборке образа переменные VITE_* вшиваются в JS (не runtime).
# Пример:
#   docker build --build-arg VITE_API_BASE=https://reclama-api.onrender.com -t reclama-front .
# На Render: в сервисе → Settings → Docker → Build Args: VITE_API_BASE, при необходимости VITE_WS_URL.
# CORS и WebSocket (SockJS/STOMP) должны быть разрешены на Spring Boot для origin фронта и для /ws.
