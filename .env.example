# Копируй в .env.production.local или задай в Render (Static Site → Environment).
# Имя ключа: ровно VITE_API_BASE. URL бэкенда без завершающего слэша (только публичный https).
# Для локального npm run dev НЕ ставь http://localhost:8080 — оставь пустым, работает Vite proxy.
# После изменения на Render: Save → rebuild and deploy.
VITE_API_BASE=https://reclama-5go0.onrender.com

# Если переменную не задавать: фронт ходит на тот же домен (/api/...). Тогда в Render Static
# добавь Redirects/Rewrites → Rewrite: Source /api/* → Destination https://ТВОЙ-API.onrender.com/api/*
# (аналогично /ws при STOMP, если брокер не на том же пути — задай VITE_WS_URL=wss://...)

# Необязательно: если пусто, при сборке берётся из VITE_API_BASE (wss/https)
# VITE_WS_URL=wss://reclama-api.onrender.com/ws

# --- Docker / Render (Web Service + Dockerfile) ---
# При сборке образа переменные VITE_* вшиваются в JS (не runtime).
# Пример:
#   docker build --build-arg VITE_API_BASE=https://reclama-api.onrender.com -t reclama-front .
#   опционально: --build-arg VITE_WS_URL=wss://reclama-api.onrender.com/ws  (только wss, не https)
# На Render: Docker → Build Args: VITE_API_BASE; VITE_WS_URL только если отличается от вывода из API.
# CORS и WebSocket (SockJS/STOMP) должны быть разрешены на Spring Boot для origin фронта и для /ws.
